      <property name="styleSheet">
        <string notr="true">QGroupBox {
    background-color: rgb(230,230,230); /* 设置背景颜色 */
    border: 2px solid gray;               /* 设置边框 */
    border-radius: 4px;                  /* 设置圆角半径 */
    margin-top: 0px;                     /* 设置标题上方的间距，以便显示标题 */
}

QSpinBox, QDoubleSpinBox {
	background-color: rgb(235,235,235);
	border-radius: 5px;
	border: none;
	padding: 0px;
}

QLabel, QSlider {
	background-color: rgb(230,230,230);
	border: none;
	padding: 0px;
}

QLabel {
	border-radius: 5px;
}

QPushButton {
    border: 2px solid #8f8f91;       /* 设置边框 */
    border-radius: 4px;             /* 设置圆角半径 */
    background-color: #f0f0f0;       /* 设置按钮背景颜色 */
    padding: 2px;                    /* 设置按钮内容的填充 */
    color: black;                    /* 设置按钮文字颜色 */
    font: bold 20px;                 /* 设置按钮文字字体和大小 */
    min-width: 44px;                 /* 设置按钮最小宽度 */
    min-height: 18px;                /* 设置按钮最小高度 */
}

QPushButton:hover {
    background-color: #e6e6e6;       /* 悬停时的背景颜色 */
    border: 2px solid #8a8a8d;       /* 悬停时的边框颜色 */
}</string>
